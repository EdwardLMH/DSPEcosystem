# Mainland China testing environment

ENVIRONMENT=testing-cn

# Runtime mode: single-site | hot-warm | hot-hot
CN_SDUI_RUNTIME_MODE=single-site

# Authoring mode: single-site | hot-warm | hot-hot
CN_AUTHORING_MODE=single-site

# IKP/GKE contexts
IKP_PRIMARY_CONTEXT=ikp-zhj-testing
IKP_SECONDARY_CONTEXT=ikp-nhc-testing
IKP_PRIMARY_SITE=ZHJ
IKP_SECONDARY_SITE=NHC

# Public domains
CN_SDUI_STATIC_FQDN=sdui-test.example.cn
CN_SDUI_API_FQDN=api-test.example.cn
CN_WEB_FQDN=web-test.example.cn

# Tencent COS/CDN
TENCENT_COS_BUCKET=hsbc-sdui-testing-cn
TENCENT_COS_REGION=ap-shanghai
TENCENT_CDN_DOMAIN=sdui-test.example.cn

# Artifact source generated by scripts/generate-study-artifacts.mjs
STATIC_ARTIFACT_DIR=study-json
STATIC_HTML_DIR=study-html

# Container images
SDUI_API_IMAGE=registry.example.cn/hsbc-dsp/bff-java:testing
KONG_IMAGE=kong:3.7

# SensorData
SENSORDATA_ENDPOINT=https://sensordata.example.cn/sa

