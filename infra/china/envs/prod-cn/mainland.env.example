# Mainland China production environment

ENVIRONMENT=prod-cn

# Runtime mode: single-site | hot-warm | hot-hot
CN_SDUI_RUNTIME_MODE=hot-warm

# Authoring mode: single-site | hot-warm | hot-hot
CN_AUTHORING_MODE=hot-warm

# IKP/GKE contexts
IKP_PRIMARY_CONTEXT=ikp-zhj-prod
IKP_SECONDARY_CONTEXT=ikp-nhc-prod
IKP_PRIMARY_SITE=ZHJ
IKP_SECONDARY_SITE=NHC

# Public domains
CN_SDUI_STATIC_FQDN=sdui.example.cn
CN_SDUI_API_FQDN=api.example.cn
CN_WEB_FQDN=www.example.cn

# Tencent COS/CDN
TENCENT_COS_BUCKET=hsbc-sdui-prod-cn
TENCENT_COS_REGION=ap-shanghai
TENCENT_CDN_DOMAIN=sdui.example.cn

# Artifact source generated by scripts/generate-study-artifacts.mjs
STATIC_ARTIFACT_DIR=study-json
STATIC_HTML_DIR=study-html

# Container images
SDUI_API_IMAGE=registry.example.cn/hsbc-dsp/bff-java:prod
KONG_IMAGE=kong:3.7

# SensorData
SENSORDATA_ENDPOINT=https://sensordata.example.cn/sa

